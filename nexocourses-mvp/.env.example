# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_API_KEY_2=sk-ant-... # fallback

# Google Gemini
GEMINI_API_KEY=AIza...

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Video Processing
FFMPEG_PATH=/usr/bin/ffmpeg

# ElevenLabs (Voice Synthesis)
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_API_BASE=https://api.elevenlabs.io

# HeyGen (Avatar Rendering)
HEYGEN_API_KEY=...
HEYGEN_API_BASE=https://api.heygen.com

# Fal.ai (Image Generation)
FALAI_API_KEY=...
FALAI_API_BASE=https://api.fal.ai

# Deepgram (Transcription)
DEEPGRAM_API_KEY=...

# Google APIs
GOOGLE_SCHOLAR_API_KEY=...
YOUTUBE_API_KEY=...
GOOGLE_SEARCH_API_KEY=...

# Hotmart (Payments)
HOTMART_CLIENT_ID=...
HOTMART_CLIENT_SECRET=...
HOTMART_WEBHOOK_SECRET=...

# Cloudflare R2 (Object Storage)
CLOUDFLARE_ACCOUNT_ID=...
CLOUDFLARE_ACCESS_KEY_ID=...
CLOUDFLARE_SECRET_ACCESS_KEY=...
CLOUDFLARE_BUCKET_NAME=nexocourses-videos

# Hotmart Webhook
WEBHOOK_SECRET=your-webhook-secret-key

# CORS
CORS_ORIGIN=http://localhost:5173,https://nexocourses.com

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Feature Flags
ENABLE_VIDEO_PROCESSING=true
ENABLE_VOICE_CLONING=false
ENABLE_RESEARCH_API=true
